We will add slices inside it

IN UTILS.JS only

import {createSlice} from "@reduxjs/toolkit";

const cartSlice=createSlice({
    name:'cart',
    initialState:{
        items:[]                       // initial state of the items
    },

    reducers:{  
             //mutating the state here    // here we have written the reducer function

            addItem:(state,action)=>{
            state.items.push(action.payload);
        },

            removeItem:(state)=>{
            state.items.pop();
        },

            clearCart: (state)=> {
            state.items.length=0

        },
        
    },
});

export const{addItem,removeItem,clearCart}=cartSlice.actions;

export default cartSlice.reducer;


create Slice function will return the object  in the cartSlice

cartSlice will have  action 

