{
  "name": "swiggy-clone",
  "version": "1.0.0",
  "description": "A React 18 clone of Swiggy's restaurant listing and menu pages, with a Redux Toolkit cart and a live Express proxy for Swiggy's API.",
  "keywords": [
    "react",
    "redux-toolkit",
    "react-router",
    "swiggy-clone"
  ],
  "homepage": "https://github.com/AKHIL1633/swiggy-clone#readme",
  "bugs": {
    "url": "https://github.com/AKHIL1633/swiggy-clone/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AKHIL1633/swiggy-clone.git"
  },
  "license": "MIT",
  "author": "Akhil P",
  "type": "commonjs",
  "scripts": {
    "start": "parcel index.html",
    "build": "parcel build index.html",
    "server": "node server.js",
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm start\"",
    "test": "jest "
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "parcel": "^2.16.4"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.3.0",
    "react-router-dom": "^6.30.3"
  },
  "browserslist": [
    "last 2 chrome version"
  ]
}
